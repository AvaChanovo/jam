<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>2026京喜造梦间Game Jam · 报名</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* ===== 全局重置 & 基础 ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #0b0e1a;
            color: #e8edf5;
            min-height: 100vh;
            padding: 20px 16px 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            max-width: 480px;
            width: 100%;
            background: linear-gradient(145deg, #131a2b, #1a2338);
            border-radius: 32px;
            padding: 24px 20px 32px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.04);
            position: relative;
            overflow: hidden;
        }

        .container::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -30%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(110, 60, 255, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }
        .container::after {
            content: '';
            position: absolute;
            bottom: -20%;
            left: -20%;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(255, 70, 150, 0.10) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }

        .header {
            position: relative;
            z-index: 1;
            text-align: center;
            margin-bottom: 28px;
        }

        .header .badge {
            display: inline-block;
            background: linear-gradient(135deg, #ff6b9d, #c44dff);
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            padding: 4px 16px;
            border-radius: 20px;
            text-transform: uppercase;
            margin-bottom: 10px;
            box-shadow: 0 4px 15px rgba(196, 77, 255, 0.35);
        }

        .header h1 {
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, #f0e9ff, #b8a5ff, #ff8dc7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 1px;
            line-height: 1.2;
        }

        .header .subtitle {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            margin-top: 6px;
            letter-spacing: 1px;
            font-weight: 300;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            padding-top: 10px;
            display: inline-block;
        }

        .header .subtitle i {
            margin-right: 6px;
            color: #ff6b9d;
        }

        .deadline {
            margin-top: 12px;
            background: rgba(255, 107, 157, 0.12);
            border: 1px solid rgba(255, 107, 157, 0.20);
            border-radius: 16px;
            padding: 10px 14px;
            font-size: 13px;
            color: #ffb3d1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            backdrop-filter: blur(4px);
        }

        .deadline i {
            font-size: 16px;
            color: #ff6b9d;
        }

        .deadline strong {
            color: #fff;
            font-weight: 700;
        }

        .form-section {
            position: relative;
            z-index: 1;
            margin-bottom: 28px;
        }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #d4dfff;
        }

        .section-title .num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
            background: linear-gradient(135deg, #6c5ce7, #a855f7);
            border-radius: 50%;
            font-size: 13px;
            font-weight: 800;
            color: #fff;
            flex-shrink: 0;
        }

        .section-title i {
            color: #a855f7;
            font-size: 18px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 6px;
            letter-spacing: 0.3px;
        }

        .form-group label .required {
            color: #ff6b9d;
            margin-left: 2px;
        }

        .form-group .hint {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.35);
            margin-top: 4px;
            font-weight: 300;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            color: #e8edf5;
            font-size: 15px;
            font-family: inherit;
            transition: all 0.25s ease;
            outline: none;
            backdrop-filter: blur(4px);
        }

        .form-control:focus {
            border-color: #a855f7;
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 0 4px rgba(168, 85, 247, 0.12);
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.25);
            font-weight: 300;
            font-size: 14px;
        }

        .form-control.textarea {
            min-height: 80px;
            resize: vertical;
            line-height: 1.6;
        }

        .member-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
            margin-top: 12px;
            margin-bottom: 12px;
        }

        .member-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 16px;
            padding: 14px 14px 10px;
            position: relative;
            transition: all 0.2s;
        }

        .member-item .member-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .member-item .member-row .form-group {
            flex: 1;
            min-width: 100px;
            margin-bottom: 8px;
        }

        .member-item .member-row .form-group label {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.4);
            margin-bottom: 3px;
        }

        .member-item .member-row .form-group .form-control {
            padding: 8px 12px;
            font-size: 13px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 10px;
        }

        .member-item .remove-member {
            position: absolute;
            top: 8px;
            right: 10px;
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.2);
            font-size: 16px;
            cursor: pointer;
            transition: color 0.2s;
            padding: 4px 6px;
            border-radius: 8px;
        }

        .member-item .remove-member:hover {
            color: #ff6b9d;
            background: rgba(255, 107, 157, 0.10);
        }

        .btn-add-member {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: rgba(168, 85, 247, 0.12);
            border: 1px dashed rgba(168, 85, 247, 0.30);
            border-radius: 14px;
            color: #c4b5fd;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.25s;
            font-family: inherit;
            backdrop-filter: blur(4px);
        }

        .btn-add-member:hover {
            background: rgba(168, 85, 247, 0.20);
            border-color: #a855f7;
            color: #fff;
            transform: translateY(-1px);
        }

        .btn-add-member i {
            font-size: 14px;
        }

        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 14px;
            margin: 16px 0 8px;
        }

        .checkbox-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            cursor: pointer;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.75);
            line-height: 1.5;
            padding: 4px 0;
        }

        .checkbox-item input[type="checkbox"] {
            appearance: none;
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            min-width: 20px;
            border: 2px solid rgba(255, 255, 255, 0.15);
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.04);
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
            top: 1px;
            flex-shrink: 0;
        }

        .checkbox-item input[type="checkbox"]:checked {
            background: linear-gradient(135deg, #6c5ce7, #a855f7);
            border-color: #a855f7;
            box-shadow: 0 4px 12px rgba(168, 85, 247, 0.30);
        }

        .checkbox-item input[type="checkbox"]:checked::after {
            content: '✓';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
        }

        .checkbox-item .label-text {
            flex: 1;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            margin-top: 12px;
            background: linear-gradient(135deg, #6c5ce7, #a855f7);
            border: none;
            border-radius: 16px;
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 30px rgba(168, 85, 247, 0.30);
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            position: relative;
            z-index: 1;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(168, 85, 247, 0.45);
        }

        .btn-submit:active {
            transform: translateY(0px);
            box-shadow: 0 4px 20px rgba(168, 85, 247, 0.30);
        }

        .btn-submit i {
            font-size: 20px;
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none !important;
        }

        .footer {
            position: relative;
            z-index: 1;
            text-align: center;
            margin-top: 28px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 12px;
            color: rgba(255, 255, 255, 0.25);
            letter-spacing: 0.5px;
        }

        .footer .org {
            color: rgba(255, 255, 255, 0.40);
            font-weight: 500;
        }

        .footer i {
            color: #ff6b9d;
            margin: 0 4px;
        }

        .toast {
            position: fixed;
            top: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(-80px);
            background: rgba(20, 28, 50, 0.95);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 14px 28px;
            border-radius: 20px;
            color: #e8edf5;
            font-size: 14px;
            font-weight: 500;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
            z-index: 999;
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
            opacity: 0;
            pointer-events: none;
            max-width: 90%;
            text-align: center;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
            pointer-events: auto;
        }

        .toast.success {
            border-color: rgba(52, 211, 153, 0.30);
        }
        .toast.success i {
            color: #34d399;
        }

        .toast.error {
            border-color: rgba(251, 113, 133, 0.30);
        }
        .toast.error i {
            color: #fb7185;
        }

        .toast i {
            font-size: 20px;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(168, 85, 247, 0.3);
            border-radius: 10px;
        }

        @media (max-width: 420px) {
            .container {
                padding: 18px 14px 24px;
            }
            .header h1 {
                font-size: 22px;
            }
            .member-item .member-row {
                flex-direction: column;
                gap: 4px;
            }
            .member-item .member-row .form-group {
                min-width: auto;
            }
            .btn-submit {
                font-size: 16px;
                padding: 14px;
            }
        }

        @media (min-width: 600px) {
            body {
                padding: 40px 20px;
            }
            .container {
                border-radius: 40px;
                padding: 32px 28px 36px;
            }
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2.5px solid rgba(255, 255, 255, 0.2);
            border-top: 2.5px solid #fff;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            vertical-align: middle;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .tag {
            display: inline-block;
            font-size: 10px;
            font-weight: 600;
            background: rgba(168, 85, 247, 0.15);
            color: #c4b5fd;
            padding: 1px 10px;
            border-radius: 20px;
            margin-left: 6px;
            letter-spacing: 0.3px;
        }
    </style>
</head>
<body>

    <div id="toast" class="toast">
        <i class="fas fa-check-circle"></i>
        <span id="toastMsg">报名成功！</span>
    </div>

    <div class="container">

        <div class="header">
            <div class="badge">
                <i class="fas fa-gamepad" style="margin-right:6px;"></i> 2026 · 北京
            </div>
            <h1>京喜造梦间<br />Game Jam</h1>
            <div class="subtitle">
                <i class="fas fa-calendar-alt"></i> 报名截止 · 2026.08.26 16:00
            </div>
            <div class="deadline">
                <i class="fas fa-clock"></i>
                <span>距报名截止还有 <strong id="countdown">--</strong></span>
            </div>
        </div>

        <form id="signupForm" novalidate>

            <!-- ====== 个人信息 ====== -->
            <div class="form-section">
                <div class="section-title">
                    <span class="num">1</span>
                    个人信息
                    <span class="tag">必填</span>
                </div>

                <div class="form-group">
                    <label>姓名 <span class="required">*</span></label>
                    <input type="text" class="form-control" id="name" placeholder="请输入你的真实姓名" required />
                </div>

                <div class="form-group">
                    <label>手机号 <span class="required">*</span></label>
                    <input type="tel" class="form-control" id="phone" placeholder="请输入手机号" required />
                </div>

                <div class="form-group">
                    <label>微信号</label>
                    <input type="text" class="form-control" id="wechat" placeholder="请输入微信号" />
                </div>

                <div class="form-group">
                    <label>QQ号</label>
                    <input type="text" class="form-control" id="qq" placeholder="请输入QQ号" />
                </div>

                <div class="form-group">
                    <label>所属院校 <span class="required">*</span></label>
                    <input type="text" class="form-control" id="school" placeholder="例：中国传媒大学 或 独立开发者" required />
                    <div class="hint">独立开发者请填写「独立开发者」</div>
                </div>
            </div>

            <!-- ====== 团队信息 ====== -->
            <div class="form-section">
                <div class="section-title">
                    <span class="num">2</span>
                    团队信息
                    <span class="tag">必填</span>
                </div>

                <div class="form-group">
                    <label>团队名称 <span class="required">*</span></label>
                    <input type="text" class="form-control" id="teamName" placeholder="给你的团队起个名字" required />
                </div>

                <div class="form-group">
                    <label>团队人数 <span class="required">*</span></label>
                    <input type="number" class="form-control" id="teamSize" placeholder="例如：3" min="1" max="20" required />
                </div>

                <div class="form-group">
                    <label>团队队长 / 主要联系人姓名 <span class="required">*</span></label>
                    <input type="text" class="form-control" id="leaderName" placeholder="队长姓名" required />
                </div>

                <div class="form-group">
                    <label>团队队长 / 主要联系人手机号 <span class="required">*</span></label>
                    <input type="tel" class="form-control" id="leaderPhone" placeholder="队长手机号" required />
                </div>

                <div class="form-group">
                    <label>团队简介（200字以内）</label>
                    <textarea class="form-control textarea" id="teamIntro" placeholder="介绍一下你的团队吧～" maxlength="200"></textarea>
                    <div class="hint" id="introCount">0 / 200</div>
                </div>

                <!-- 团队成员列表 -->
                <div style="margin-top: 8px;">
                    <label style="font-size:13px;font-weight:500;color:rgba(255,255,255,0.7);display:block;margin-bottom:8px;">
                        团队成员 <span class="required">*</span>
                    </label>
                    <div id="memberContainer" class="member-list">
                        <!-- 默认一个成员（无队长标记） -->
                        <div class="member-item" data-index="0">
                            <div class="member-row">
                                <div class="form-group">
                                    <label>姓名 <span class="required">*</span></label>
                                    <input type="text" class="form-control member-name" placeholder="姓名" required />
                                </div>
                                <div class="form-group">
                                    <label>手机号 <span class="required">*</span></label>
                                    <input type="tel" class="form-control member-phone" placeholder="手机号" required />
                                </div>
                                <div class="form-group" style="flex:1.2;min-width:120px;">
                                    <label>担任团队角色 <span class="required">*</span></label>
                                    <input type="text" class="form-control member-role" placeholder="如：策划/程序/美术" required />
                                </div>
                            </div>
                            <button type="button" class="remove-member" style="display:none;" title="移除成员">
                                <i class="fas fa-times-circle"></i>
                            </button>
                        </div>
                    </div>
                    <button type="button" class="btn-add-member" id="addMemberBtn">
                        <i class="fas fa-user-plus"></i> 添加成员
                    </button>
                </div>
            </div>

            <!-- ====== 收获期望 ====== -->
            <div class="form-section">
                <div class="section-title">
                    <span class="num">3</span>
                    你希望从本次 Game Jam 中收获什么？
                </div>
                <div class="form-group">
                    <textarea class="form-control textarea" id="expectation" placeholder="分享你的期待，让我们更了解你～" style="min-height:70px;"></textarea>
                </div>
            </div>

            <!-- ====== 同意条款 ====== -->
            <div class="form-section" style="margin-bottom:16px;">
                <div class="section-title" style="font-size:14px;margin-bottom:10px;">
                    <i class="fas fa-shield-alt" style="color:#6c5ce7;"></i> 确认与授权
                </div>
                <div class="checkbox-group">
                    <label class="checkbox-item">
                        <input type="checkbox" id="agreeContact" required />
                        <span class="label-text">
                            我同意主办方通过电话、微信、短信等渠道联系我，发送活动相关通知。
                            <span class="required">*</span>
                        </span>
                    </label>
                    <label class="checkbox-item">
                        <input type="checkbox" id="agreeDisplay" required />
                        <span class="label-text">
                            我了解入围作品可能用于活动宣传及展示，主办方将保护创作者署名权。
                            <span class="required">*</span>
                        </span>
                    </label>
                </div>
            </div>

            <button type="submit" class="btn-submit" id="submitBtn">
                <i class="fas fa-paper-plane"></i> 立即报名
            </button>

        </form>

        <div class="footer">
            <span class="org">主办：北京市出版版权协会 · 北京市朝阳区人民政府</span>
            <br />
            <i class="fas fa-heart" style="color:#ff6b9d;"></i> 京喜造梦 · 2026
        </div>

    </div>

    <script>
        (function() {
            'use strict';

            const form = document.getElementById('signupForm');
            const toast = document.getElementById('toast');
            const toastMsg = document.getElementById('toastMsg');
            const memberContainer = document.getElementById('memberContainer');
            const addMemberBtn = document.getElementById('addMemberBtn');
            const submitBtn = document.getElementById('submitBtn');
            const introText = document.getElementById('teamIntro');
            const introCount = document.getElementById('introCount');

            // ===== 倒计时 =====
            function updateCountdown() {
                const target = new Date('2026-08-26T16:00:00+08:00').getTime();
                const now = Date.now();
                const diff = target - now;
                const el = document.getElementById('countdown');
                if (diff <= 0) {
                    el.textContent = '已截止';
                    return;
                }
                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const secs = Math.floor((diff % (1000 * 60)) / 1000);
                el.textContent = `${days}天 ${String(hours).padStart(2,'0')}:${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;
            }
            updateCountdown();
            setInterval(updateCountdown, 1000);

            // ===== 简介字数统计 =====
            introText.addEventListener('input', function() {
                const len = this.value.length;
                introCount.textContent = `${len} / 200`;
                if (len > 200) {
                    this.value = this.value.slice(0, 200);
                    introCount.textContent = '200 / 200';
                }
            });

            // ===== 团队成员管理 =====
            let memberIndex = 1;

            function createMemberItem(index) {
                const div = document.createElement('div');
                div.className = 'member-item';
                div.dataset.index = index;
                div.innerHTML = `
                    <div class="member-row">
                        <div class="form-group">
                            <label>姓名 <span class="required">*</span></label>
                            <input type="text" class="form-control member-name" placeholder="姓名" required />
                        </div>
                        <div class="form-group">
                            <label>手机号 <span class="required">*</span></label>
                            <input type="tel" class="form-control member-phone" placeholder="手机号" required />
                        </div>
                        <div class="form-group" style="flex:1.2;min-width:120px;">
                            <label>担任团队角色 <span class="required">*</span></label>
                            <input type="text" class="form-control member-role" placeholder="如：策划/程序/美术" required />
                        </div>
                    </div>
                    <button type="button" class="remove-member" title="移除成员">
                        <i class="fas fa-times-circle"></i>
                    </button>
                `;
                const removeBtn = div.querySelector('.remove-member');
                removeBtn.addEventListener('click', function() {
                    if (memberContainer.children.length <= 1) {
                        showToast('至少保留一位成员（队长）', 'error');
                        return;
                    }
                    div.remove();
                });
                return div;
            }

            addMemberBtn.addEventListener('click', function() {
                const item = createMemberItem(memberIndex++);
                memberContainer.appendChild(item);
                item.scrollIntoView({ behavior: 'smooth', block: 'center' });
            });

            // 第一个成员的移除按钮隐藏（不可删除，但无队长标记）
            const firstRemove = memberContainer.querySelector('.remove-member');
            if (firstRemove) firstRemove.style.display = 'none';

            // ===== Toast =====
            let toastTimer = null;

            function showToast(msg, type = 'success') {
                const icon = toast.querySelector('i');
                if (type === 'success') {
                    icon.className = 'fas fa-check-circle';
                    toast.className = 'toast success';
                } else {
                    icon.className = 'fas fa-exclamation-circle';
                    toast.className = 'toast error';
                }
                toastMsg.textContent = msg;
                toast.classList.add('show');
                clearTimeout(toastTimer);
                toastTimer = setTimeout(() => {
                    toast.classList.remove('show');
                }, 3500);
            }

            // ===== 表单验证 & 提交 =====
            form.addEventListener('submit', function(e) {
                e.preventDefault();

                const name = document.getElementById('name').value.trim();
                const phone = document.getElementById('phone').value.trim();
                const school = document.getElementById('school').value.trim();
                const teamName = document.getElementById('teamName').value.trim();
                const teamSize = document.getElementById('teamSize').value.trim();
                const leaderName = document.getElementById('leaderName').value.trim();
                const leaderPhone = document.getElementById('leaderPhone').value.trim();
                const agreeContact = document.getElementById('agreeContact').checked;
                const agreeDisplay = document.getElementById('agreeDisplay').checked;

                if (!name) { showToast('请填写姓名', 'error'); return; }
                if (!phone) { showToast('请填写手机号', 'error'); return; }
                if (!/^1\d{10}$/.test(phone)) { showToast('请输入正确的11位手机号', 'error'); return; }
                if (!school) { showToast('请填写所属院校', 'error'); return; }
                if (!teamName) { showToast('请填写团队名称', 'error'); return; }
                if (!teamSize || parseInt(teamSize) < 1) { showToast('请填写有效的团队人数', 'error'); return; }
                if (!leaderName) { showToast('请填写队长姓名', 'error'); return; }
                if (!leaderPhone) { showToast('请填写队长手机号', 'error'); return; }
                if (!/^1\d{10}$/.test(leaderPhone)) { showToast('请输入正确的队长手机号', 'error'); return; }
                if (!agreeContact) { showToast('请同意主办方联系授权', 'error'); return; }
                if (!agreeDisplay) { showToast('请同意作品宣传展示条款', 'error'); return; }

                const memberItems = memberContainer.querySelectorAll('.member-item');
                const membersData = [];
                let memberValid = true;

                memberItems.forEach((item) => {
                    const nameInput = item.querySelector('.member-name');
                    const phoneInput = item.querySelector('.member-phone');
                    const roleInput = item.querySelector('.member-role');
                    const mName = nameInput ? nameInput.value.trim() : '';
                    const mPhone = phoneInput ? phoneInput.value.trim() : '';
                    const mRole = roleInput ? roleInput.value.trim() : '';

                    if (!mName || !mPhone || !mRole) {
                        memberValid = false;
                        if (!mName) nameInput?.focus();
                        else if (!mPhone) phoneInput?.focus();
                        else if (!mRole) roleInput?.focus();
                        return;
                    }
                    if (!/^1\d{10}$/.test(mPhone)) {
                        memberValid = false;
                        showToast(`团队成员「${mName}」手机号格式不正确`, 'error');
                        phoneInput?.focus();
                        return;
                    }
                    membersData.push({ name: mName, phone: mPhone, role: mRole });
                });

                if (!memberValid) {
                    if (membersData.length === 0) {
                        showToast('请至少添加一位团队成员（队长）', 'error');
                    } else {
                        showToast('请完整填写所有团队成员信息', 'error');
                    }
                    return;
                }

                const declaredSize = parseInt(teamSize);
                if (membersData.length !== declaredSize) {
                    showToast(`团队人数声明为 ${declaredSize}，但实际填写了 ${membersData.length} 位成员`, 'error');
                    return;
                }

                const formData = {
                    personal: {
                        name,
                        phone,
                        wechat: document.getElementById('wechat').value.trim(),
                        qq: document.getElementById('qq').value.trim(),
                        school,
                    },
                    team: {
                        name: teamName,
                        size: declaredSize,
                        leaderName,
                        leaderPhone,
                        intro: document.getElementById('teamIntro').value.trim(),
                        members: membersData,
                    },
                    expectation: document.getElementById('expectation').value.trim(),
                    agreements: {
                        contact: agreeContact,
                        display: agreeDisplay,
                    },
                    submittedAt: new Date().toISOString(),
                };

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner"></span> 提交中...';

                setTimeout(() => {
                    console.log('📦 报名数据:', JSON.stringify(formData, null, 2));
                    showToast('🎉 报名成功！我们将在48小时内与你联系', 'success');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-check"></i> 已报名';
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }, 1200);
            });

            // ===== 手机号仅数字 =====
            document.querySelectorAll('input[type="tel"]').forEach(input => {
                input.addEventListener('input', function() {
                    this.value = this.value.replace(/\D/g, '');
                });
            });

            // ===== 移除所有“队长”标记（初始化无标记，动态添加也无标记） =====
            // 无需额外操作，因为默认第一个成员没有特殊标记，动态添加的也没有。

        })();
    </script>

</body>
</html>
